    "ua-parser-js": "^2.0.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.5.0",
    "@types/bun": "latest",
    "@types/ua-parser-js": "^0.7.0",
    "testcontainers": "^10.13.0",
    "@testcontainers/postgresql": "^10.13.0"
  }
