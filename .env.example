# Generate strong values with: openssl rand -hex 32
# (or PowerShell: -join ((48..57) + (97..122) | Get-Random -Count 64 | % {[char]$_}))
POSTGRES_PASSWORD=replace-with-strong-random-value
IP_HASH_SALT=replace-with-strong-random-value-min-32-chars
ADMIN_TOKEN=replace-with-strong-random-value-min-32-chars
FRONTEND_ORIGIN=https://your-domain.com
ADMIN_ORIGIN=https://admin.your-domain.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
