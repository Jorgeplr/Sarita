# ============================================
# Valores para Dokploy (produccion).
# Copia este archivo a .env en Dokploy o pega
# cada variable en la pestana "Environment" de
# la aplicacion Compose.
#
# Genera valores fuertes con:
#   openssl rand -hex 32
# ============================================

# Postgres (al menos 24 caracteres aleatorios)
POSTGRES_PASSWORD=cambiame-postgres-password-fuerte

# Backend - secretos (32+ caracteres hex)
IP_HASH_SALT=cambiame-32-chars-min-aleatorios-aqui
ADMIN_TOKEN=cambiame-32-chars-min-aleatorios-aqui

# Dominios publicos (https://). DEBEN coincidir EXACTO
# con lo que escribas en la pestana Domains de Dokploy,
# si no la cookie de sesion y el CORS fallan.
FRONTEND_ORIGIN=https://sarita.tudominio.com
ADMIN_ORIGIN=https://admin-sarita.tudominio.com

# Usuario admin inicial. Si cambias la password aqui
# y rebuilds, se sincroniza automaticamente.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-password
